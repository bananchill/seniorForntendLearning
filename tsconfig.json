{
	"compilerOptions": {
		"module": "CommonJS",
		"target": "ES2022",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"types": ["node"],
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true
	},
	"exclude": ["node_modules", "dist"]
}
